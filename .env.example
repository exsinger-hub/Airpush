# OpenAI
OPENAI_API_KEY=EMPTY
# 可选：兼容 OpenAI 协议的第三方网关（如 DeepSeek）
# 示例: https://api.deepseek.com/v1
# 直连示例: http://YOUR_SERVER_IP:8000/v1
# 隧道示例: http://localhost:8000/v1
OPENAI_BASE_URL=http://localhost:8000/v1

# 模型可按供应商替换
# OpenAI 默认: gpt-4o-mini / gpt-4o
# DeepSeek 示例: deepseek-chat / deepseek-reasoner
LLM_QUICK_MODEL=qwen-72b
LLM_DEEP_MODEL=qwen-72b
DISABLE_LOCAL_QUICK=true
LLM_REQUEST_TIMEOUT=180
LLM_DEEP_EXTRACT_MAX_TOKENS=8192
LLM_ABSTRACT_TRANSLATE_MAX_TOKENS=4096
LLM_MAX_INPUT_TOKENS=24000

# Figure hosting (optional, GitHub + jsDelivr)
FIGURE_HOSTING_ENABLED=false
FIGURE_MAX_IMAGES=3
GITHUB_TOKEN=
GITHUB_USER=
GITHUB_REPO=
GITHUB_BRANCH=main
GITHUB_UPLOAD_TIMEOUT=20

# Notion (optional)
NOTION_TOKEN=
NOTION_DB_ID=

# Notifications
WEBHOOK_URL=
ALERT_URL=

# PubMed email (recommended by NCBI)
PUBMED_EMAIL=your-email@example.com

# Runtime
DRY_RUN=true
